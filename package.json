{
  "name": "labwindows-cvi-project-manager",
  "displayName": "LabWindows/CVI Project Manager",
  "description": "Manage LabWindows/CVI workspaces and projects directly from Visual Studio Code.",
  "version": "0.6.5",
  "publisher": "JerryCrozet-ElectronicEngineer",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "LabWindows",
    "CVI",
    "National Instruments",
    "NI",
    "C"
  ],
  "activationEvents": [
    "onView:labwindowsCvi.quickActions",
    "onView:labwindowsCvi.workspaceExplorer",
    "onCommand:labwindowsCvi.openHome",
    "onView:labwindowsCvi.libraryExplorer",
    "onCommand:labwindowsCvi.debugInCvi",
    "onCommand:labwindowsCvi.library.findFunction",
    "onCommand:labwindowsCvi.library.managePacks",
    "onCommand:labwindowsCvi.library.reloadPacks",
    "onCommand:labwindowsCvi.insertSnippet",
    "onCommand:labwindowsCvi.saveSelectionAsSnippet",
    "onCommand:labwindowsCvi.manageSnippets",
    "onCommand:labwindowsCvi.saveFileAsTemplate",
    "onCommand:labwindowsCvi.importFileTemplate",
    "onCommand:labwindowsCvi.manageFileTemplates",
    "onCommand:labwindowsCvi.diagnoseCppTools",
    "onCommand:labwindowsCvi.addWorkspaceFolderForIntelliSense",
    "onCommand:labwindowsCvi.repairCppToolsProvider",
    "onCommand:labwindowsCvi.repairNativeWorkspaceCompatibility",
    "onCommand:labwindowsCvi.chooseBuildAction",
    "onCommand:labwindowsCvi.clean",
    "onCommand:labwindowsCvi.cleanProject",
    "onCommand:labwindowsCvi.selectTargetType",
    "onCommand:labwindowsCvi.editBuildSettings",
    "onCommand:labwindowsCvi.editBuildSettingsSafeMode",
    "onCommand:labwindowsCvi.generatePrototypes",
    "onView:labwindowsCvi.fileSymbols",
    "onCommand:labwindowsCvi.refreshFileSymbols",
    "onCommand:labwindowsCvi.revealFileSymbol",
    "onCommand:labwindowsCvi.chooseRunAction",
    "onCommand:labwindowsCvi.runWithoutBuild",
    "onCommand:labwindowsCvi.selectBuildModeD32",
    "onCommand:labwindowsCvi.selectBuildModeR32",
    "onCommand:labwindowsCvi.selectBuildModeD64",
    "onCommand:labwindowsCvi.selectBuildModeR64",
    "onCommand:labwindowsCvi.selectTargetTypeEXE",
    "onCommand:labwindowsCvi.selectTargetTypeDLL",
    "onCommand:labwindowsCvi.selectTargetTypeLIB",
    "onCommand:labwindowsCvi.prepareDllImportLibraryGeneration",
    "onCommand:labwindowsCvi.copyFilePath",
    "onCommand:labwindowsCvi.copyRelativeFilePath"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "labwindowsCvi",
          "title": "LabWindows/CVI",
          "icon": "media/cvi.svg"
        }
      ]
    },
    "views": {
      "labwindowsCvi": [
        {
          "id": "labwindowsCvi.workspaceExplorer",
          "name": "CVI Workspace",
          "contextualTitle": "LabWindows/CVI",
          "showCollapseAll": true
        },
        {
          "id": "labwindowsCvi.quickActions",
          "name": "CVI Actions",
          "contextualTitle": "CVI Actions",
          "visibility": "visible",
          "showCollapseAll": false
        },
        {
          "id": "labwindowsCvi.fileSymbols",
          "name": "CVI File Symbols",
          "contextualTitle": "CVI File Symbols",
          "showCollapseAll": false
        },
        {
          "id": "labwindowsCvi.libraryExplorer",
          "name": "CVI Libraries",
          "contextualTitle": "CVI Libraries",
          "showCollapseAll": true
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "labwindowsCvi.workspaceExplorer",
        "contents": "No LabWindows/CVI workspace is currently loaded.\n[Open a workspace](command:labwindowsCvi.openWorkspace)\n[Create a workspace and project](command:labwindowsCvi.createWorkspaceProject)\n[Open the CVI home page](command:labwindowsCvi.openHome)"
      }
    ],
