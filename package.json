    "menus": {
      "view/title": [
        {
          "command": "labwindowsCvi.library.findFunction",
          "when": "view == labwindowsCvi.libraryExplorer",
          "group": "navigation@1"
        },
        {
          "command": "labwindowsCvi.library.clearFind",
          "when": "view == labwindowsCvi.libraryExplorer",
          "group": "navigation@2"
        },
        {
          "command": "labwindowsCvi.library.managePacks",
          "when": "view == labwindowsCvi.libraryExplorer",
          "group": "navigation@3"
        },
        {
          "command": "labwindowsCvi.library.openVisualEditor",
          "when": "view == labwindowsCvi.libraryExplorer",
          "group": "navigation@4"
        },
        {
          "command": "labwindowsCvi.library.reloadPacks",
          "when": "view == labwindowsCvi.libraryExplorer",
          "group": "navigation@5"
        },
        {
          "command": "labwindowsCvi.refreshFileSymbols",
          "when": "view == labwindowsCvi.fileSymbols",
          "group": "navigation@1"
        },
        {
          "command": "labwindowsCvi.openHome",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@1"
        },
        {
          "command": "labwindowsCvi.openWorkspace",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@2"
        },
        {
          "command": "labwindowsCvi.chooseBuildAction",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@3"
        },
        {
          "command": "labwindowsCvi.run",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@4"
        },
        {
          "command": "labwindowsCvi.chooseRunAction",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@5"
        },
        {
          "command": "labwindowsCvi.selectBuildModeD32",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.buildMode == debug",
          "group": "navigation@6"
        },
        {
          "command": "labwindowsCvi.selectBuildModeR32",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.buildMode == release",
          "group": "navigation@6"
        },
        {
          "command": "labwindowsCvi.selectBuildModeD64",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.buildMode == debug64",
          "group": "navigation@6"
        },
        {
          "command": "labwindowsCvi.selectBuildModeR64",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.buildMode == release64",
          "group": "navigation@6"
        },
        {
          "command": "labwindowsCvi.selectTargetTypeEXE",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.targetType == exe",
          "group": "navigation@7"
        },
        {
          "command": "labwindowsCvi.selectTargetTypeDLL",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.targetType == dll",
          "group": "navigation@7"
        },
        {
          "command": "labwindowsCvi.selectTargetTypeLIB",
          "when": "view == labwindowsCvi.workspaceExplorer && labwindowsCvi.targetType == lib",
          "group": "navigation@7"
        },
        {
          "command": "labwindowsCvi.editBuildSettings",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@8"
        },
        {
          "command": "labwindowsCvi.refresh",
          "when": "view == labwindowsCvi.workspaceExplorer",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "labwindowsCvi.openWorkspaceInCvi",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviWorkspace",
          "group": "inline@1"
        },
        {
          "command": "labwindowsCvi.addExistingProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviWorkspace",
          "group": "modification@1"
        },
        {
          "command": "labwindowsCvi.repairNativeWorkspaceCompatibility",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviWorkspace",
          "group": "modification@2"
        },
        {
          "command": "labwindowsCvi.saveAll",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "project@1"
        },
        {
          "command": "labwindowsCvi.setActiveProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "project@2"
        },
        {
          "command": "labwindowsCvi.buildProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "build@1"
        },
        {
          "command": "labwindowsCvi.rebuildProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "build@2"
        },
        {
          "command": "labwindowsCvi.editProjectInCvi",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "build@4"
        },
        {
          "command": "labwindowsCvi.executeProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "build@5"
        },
        {
          "command": "labwindowsCvi.chooseRunAction",
          "group": "build@5.5",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject"
        },
        {
          "command": "labwindowsCvi.removeProject",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "build@6"
        },
        {
          "command": "labwindowsCvi.addFolder",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "modification@1"
        },
        {
          "command": "labwindowsCvi.addFiles",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "modification@2"
        },
        {
          "command": "labwindowsCvi.createNewFile",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "modification@3"
        },
        {
          "command": "labwindowsCvi.openProjectFile",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "navigation@1"
        },
        {
          "command": "labwindowsCvi.revealProjectFile",
          "when": "view == labwindowsCvi.workspaceExplorer && viewItem == cviProject",
          "group": "navigation@2"
        },
