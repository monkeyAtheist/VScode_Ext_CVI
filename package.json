    "configuration": {
      "title": "LabWindows/CVI Project Manager",
      "properties": {
        "labwindowsCvi.installations": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Known LabWindows/CVI installation root directories. Example: C:\\Program Files (x86)\\National Instruments\\CVI2012"
        },
        "labwindowsCvi.activeInstallation": {
          "type": "string",
          "default": "",
          "description": "Selected LabWindows/CVI installation root directory. Leave empty to use automatic detection."
        },
        "labwindowsCvi.buildMode": {
          "type": "string",
          "enum": [
            "debug",
            "release",
            "debug64",
            "release64"
          ],
          "default": "debug",
          "description": "Build mode passed to compile.exe."
        },
        "labwindowsCvi.customBuildConfiguration": {
          "type": "string",
          "default": "",
          "description": "Optional CVI custom build configuration name passed through -config=..."
        },
        "labwindowsCvi.extraCompilerArguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments appended to compile.exe invocations."
        },
        "labwindowsCvi.runArguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the active executable when running it."
        },
        "labwindowsCvi.projectFormatVersion": {
          "type": "number",
          "default": 1200,
          "minimum": 1,
          "description": "Version value used when generating new .cws and .prj files. The default matches the supplied CVI 2012 examples."
        },
        "labwindowsCvi.autoLoadWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Automatically load a .cws file when the opened VS Code folder contains exactly one CVI workspace."
        },
        "labwindowsCvi.autoConfigureCppTools": {
          "type": "boolean",
          "default": true,
          "description": "Automatically create or update the managed LabWindows/CVI entry in .vscode/c_cpp_properties.json when a CVI workspace is opened or the selected installation changes."
        },
        "labwindowsCvi.autoAddCviFolderToWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add the directory containing an opened CVI .cws or .prj file to the standard VS Code Explorer. This activates the generated .vscode/c_cpp_properties.json file and improves header resolution."
        },
        "labwindowsCvi.uirTemplateVersion": {
          "type": "string",
          "enum": [
            "auto",
            "cvi2012",
            "cvi2020"
          ],
          "default": "auto",
          "description": "Blank .uir binary template used when creating CVI panels. auto selects CVI 2020 for a CVI2020 installation and otherwise uses the CVI 2012-compatible template."
        },
        "labwindowsCvi.useCppToolsConfigurationProvider": {
          "type": "boolean",
          "default": false,
          "description": "Deprecated compatibility switch. Dynamic C/C++ provider registration is no longer used because it can override IntelliSense outside CVI workspaces. The extension manages c_cpp_properties.json directly.",
          "deprecationMessage": "Deprecated since 0.6.0. The dynamic provider is disabled permanently; use the generated c_cpp_properties.json configuration."
        },
        "labwindowsCvi.intelliSenseCompilerPath": {
          "type": "string",
          "default": "",
          "description": "Optional explicit compiler executable used by Microsoft C/C++ IntelliSense. Leave empty to auto-detect the internal CVI Clang executable."
        },
        "labwindowsCvi.additionalIncludePaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional include directories appended to the generated CVI IntelliSense configuration and dynamic provider."
        },
        "labwindowsCvi.enableSupplementalCompletionProvider": {
          "type": "boolean",
          "default": true,
          "description": "Provide supplemental C/C++ completion items from the active CVI workspace and the embedded CVI API pack. The provider is scoped to CVI workspace files and does not run in unrelated C/C++ folders."
        },
        "labwindowsCvi.showPersistentStatusBarActions": {
          "type": "boolean",
          "default": true,
          "description": "Show compact LabWindows/CVI actions in the VS Code status bar. These actions remain available when the CVI Workspace view is collapsed."
        }
      }
    },
    "keybindings": [
      {
        "command": "labwindowsCvi.library.findFunction",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "labwindowsCvi.insertSnippet",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  },
  "icon": "media/cvi-marketplace.png"
}
